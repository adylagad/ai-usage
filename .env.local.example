# ============================================================
# AI Usage Tracker — Environment Variables
# Copy this file to .env.local and fill in your credentials.
# ============================================================

# --- Claude & OpenAI Codex CLI ---
# No API keys needed! Usage is read directly from local files:
#   Claude:     ~/.claude/projects/**/*.jsonl
#   Codex CLI:  ~/.codex/sessions/**/*.jsonl

# --- Cursor ---
# Enterprise teams only. Get your API key from Cursor team settings.
CURSOR_API_KEY=

# --- GitHub Copilot ---
# Requires org/enterprise Copilot plan. Personal accounts are not supported.
# GITHUB_TOKEN=ghp_...
# GITHUB_ORG=your-org-name

# --- App Settings ---
# Cache TTL in minutes (default: 5). Increase to reduce API calls.
CACHE_TTL_MINUTES=5

# Base URL for internal API calls (change if running on a different port)
NEXT_PUBLIC_APP_URL=http://localhost:3000
