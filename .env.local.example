# ============================================================
# AI Usage Tracker — Environment Variables
# Copy this file to .env.local and fill in your credentials.
# ============================================================

# --- Claude & OpenAI Codex CLI ---
# No API keys needed! Usage is read directly from local files:
#   Claude:     ~/.claude/projects/**/*.jsonl
#   Codex CLI:  ~/.codex/sessions/**/*.jsonl

# --- GitHub Copilot (Personal) ---
# Sign in with GitHub via the sidebar to enable personal Copilot tracking.
# Create an OAuth App at: https://github.com/settings/developers
#   Homepage URL:      http://localhost:3000
#   Callback URL:      http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Required by NextAuth — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# --- GitHub Copilot (Org/Enterprise) ---
# Optional: if you're an org admin with Copilot Business/Enterprise.
# GITHUB_TOKEN=ghp_...
# GITHUB_ORG=your-org-name

# --- Cursor ---
# Enterprise teams only. Get your API key from Cursor team settings.
CURSOR_API_KEY=

# --- App Settings ---
# Cache TTL in minutes (default: 5). Increase to reduce API calls.
CACHE_TTL_MINUTES=5

# Base URL for internal API calls (change if running on a different port)
NEXT_PUBLIC_APP_URL=http://localhost:3000
